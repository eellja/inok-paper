---
const links = [
    { href: "/inok", label: "загальна інформація" },
    { href: "/inok/submissions", label: "подання творів" },
    { href: "/inok/events", label: "події" },
    { href: "/inok/issues", label: "архів" },
];
---

<header class="header">
    <a href="/inok" class="logo">
        <img src="/inok/інок.svg" alt="Логотип" />
    </a>

    <nav class="desktop-nav" aria-label="Навігація для комп’ютерів">
        {links.map((link) => (
                <a href={link.href}>{link.label}</a>
        ))}
    </nav>

    <details class="mobile-menu">
        <summary class="hamburger" aria-label="Увімкнути меню">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </summary>

        <nav class="mobile-nav" aria-label="Навігація для мобільних пристроїв">
            {links.map((link) => (
                    <a href={link.href}>{link.label}</a>
            ))}
        </nav>
    </details>
</header>

<style>
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;

        padding: 1rem 2rem;
        position: relative;

        background: var(--accent);
    }

    .desktop-nav {
        display: flex;
        gap: 2rem;
    }

    .desktop-nav a {
        text-decoration: none;
        color: var(--primary);
    }

    .mobile-menu {
        display: none;
    }

    @media (max-width: 768px) {
        .desktop-nav {
            display: none;
        }

        .mobile-menu {
            display: block;
            position: relative;
            z-index: 1000;
        }

        .hamburger {
            list-style: none;
        }

        .hamburger::-webkit-details-marker {
            display: none;
        }

        .hamburger::marker {
            display: none;
        }

        .hamburger {
            width: 32px;
            height: 32px;

            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 6px;

            cursor: pointer;
            position: relative;
            z-index: 1002;
        }

        .hamburger span {
            display: block;
            width: 24px;
            height: 3px;

            background: var(--primary);
            border-radius: 999px;

            transform-origin: center;
            transition:
                    transform 0.3s ease,
                    opacity 0.3s ease;
        }

        .mobile-nav {
            display: none;
        }

        .mobile-menu[open] {
            position: fixed;
            inset: 0;

            background: var(--primary);
            z-index: 1000;
        }

        .mobile-menu[open] .mobile-nav {
            display: flex;

            flex-direction: column;
            justify-content: center;
            align-items: start;

            padding-left: 2rem;

            gap: 2rem;
            height: 100vh;
        }

        .mobile-nav a {
            text-decoration: none;
            color: var(--accent);

            font-size: 2rem;
            font-weight: 600;
        }

        .mobile-menu[open] .hamburger {
            position: absolute;
            top: 1.5rem;
            right: 2rem;
        }

        .mobile-menu[open] .hamburger span {
            background: var(--accent);
        }

        .mobile-menu[open] .hamburger span:nth-child(1) {
            transform: translateY(9px) rotate(45deg);
        }

        .mobile-menu[open] .hamburger span:nth-child(2) {
            opacity: 0;
        }

        .mobile-menu[open] .hamburger span:nth-child(3) {
            transform: translateY(-9px) rotate(-45deg);
        }
    }
</style>