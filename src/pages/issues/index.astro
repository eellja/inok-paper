---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PdfThumbnail from "../../components/PdfThumbnail.astro"; // Import here

const issues = await getCollection("issues");
---

<BaseLayout title="архів">
    <div class="grid">
        {issues.map((issue: any) => (
                <div class="card">
                    <a href={issue.data.pdfUrl} target="_blank">
                        <h2>Номер №{issue.data.number}</h2>

                        <figure>
                            <img src={issue.data.coverUrl} width="300px" />
                        </figure>
                    </a>
                </div>
        ))}
    </div>
</BaseLayout>

<style>
    .card {
        display: inline-block;
        padding: 16px;
    }
</style>